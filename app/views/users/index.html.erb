<% content_for :title, "Bienvenido a Our Portfolio" %>

<!-- Hero Section -->
<div class="relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-purple-100 transform -skew-y-1 origin-top-left"></div>
  
  <div class="relative max-w-4xl mx-auto text-center py-16 px-4">
    <!-- Main heading -->
    <h1 class="text-5xl md:text-6xl font-extrabold text-gray-900 leading-tight">
      ¡Bienvenido a 
      <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        Our Portfolio
      </span>!
    </h1>
    
    <!-- Subtitle -->
    <p class="mt-6 text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
      Una plataforma moderna para mostrar y compartir proyectos increíbles. 
      Conecta con desarrolladores y creativos de todo el mundo.
    </p>
    
    <!-- User-specific content -->
    <% if logged_in? %>
      <div class="mt-8 p-6 bg-white rounded-2xl shadow-lg border border-gray-100">
        <div class="flex items-center justify-center mb-4">
          <div class="w-16 h-16 bg-gradient-to-r from-green-400 to-blue-500 rounded-full flex items-center justify-center">
            <i class="fas fa-user text-white text-2xl"></i>
          </div>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">
          ¡Hola, <%= current_user.name %>! 👋
        </h2>
        <p class="text-gray-600 mb-6">Es genial tenerte de vuelta en nuestra comunidad</p>
        <%= link_to current_user, class: "inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-semibold rounded-xl hover:from-blue-700 hover:to-purple-700 transition-all duration-300 transform hover:scale-105 shadow-lg" do %>
          <i class="fas fa-user-circle mr-2"></i>
          Ver mi perfil
        <% end %>
      </div>
    <% else %>
      <!-- Call to action for non-logged users -->
      <div class="mt-12 space-y-4 sm:space-y-0 sm:space-x-4 sm:flex sm:justify-center">
        <%= link_to signup_path, class: "w-full sm:w-auto flex items-center justify-center px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-bold rounded-xl hover:from-blue-700 hover:to-purple-700 transition-all duration-300 transform hover:scale-105 shadow-lg" do %>
          <i class="fas fa-rocket mr-2"></i>
          Comenzar ahora
        <% end %>
        
        <%= link_to login_path, class: "w-full sm:w-auto flex items-center justify-center px-8 py-4 bg-white text-gray-700 font-semibold rounded-xl border-2 border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-all duration-300 shadow-lg" do %>
          <i class="fas fa-sign-in-alt mr-2"></i>
          Iniciar Sesión
        <% end %>
      </div>
      
      <!-- Features -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center p-6 bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-palette text-blue-600 text-xl"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Creatividad</h3>
          <p class="text-gray-600">Muestra tus proyectos creativos con estilo</p>
        </div>
        
        <div class="text-center p-6 bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-users text-green-600 text-xl"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Comunidad</h3>
          <p class="text-gray-600">Conecta con otros desarrolladores</p>
        </div>
        
        <div class="text-center p-6 bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-chart-line text-purple-600 text-xl"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Crecimiento</h3>
          <p class="text-gray-600">Mejora tus habilidades constantemente</p>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Users Section -->
<% if @users&.any? %>
  <div class="mt-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Nuestra Comunidad</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Conoce a los talentosos miembros de nuestra comunidad y descubre sus increíbles proyectos
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @users.each do |user| %>
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 overflow-hidden">
          <!-- User header -->
          <div class="bg-gradient-to-r from-blue-500 to-purple-600 p-6 text-white text-center">
            <div class="w-20 h-20 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4">
              <i class="fas fa-user text-3xl"></i>
            </div>
            <h3 class="text-xl font-bold"><%= user.name %></h3>
          </div>
          
          <!-- User info -->
          <div class="p-6">
            <div class="flex items-center text-gray-600 mb-4">
              <i class="fas fa-calendar-alt mr-2"></i>
              <span class="text-sm">Miembro desde <%= user.created_at.strftime("%B %Y") %></span>
            </div>
            
            <div class="flex items-center text-gray-600 mb-6">
              <i class="fas fa-envelope mr-2"></i>
              <span class="text-sm"><%= user.email %></span>
            </div>
            
            <%= link_to user, class: "w-full flex items-center justify-center px-4 py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-semibold rounded-lg hover:from-blue-700 hover:to-purple-700 transition-all duration-300" do %>
              <i class="fas fa-eye mr-2"></i>
              Ver Perfil
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>