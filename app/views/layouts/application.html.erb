<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Our Portfolio" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <!-- Navegación -->
    <nav class="bg-gradient-to-r from-blue-600 to-purple-600 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo/Brand -->
          <div class="flex-shrink-0">
            <%= link_to root_path, class: "text-white text-xl font-bold hover:text-gray-200 transition-colors duration-200" do %>
              <span class="bg-white text-blue-600 px-2 py-1 rounded-lg mr-2">OP</span>
              Our Portfolio
            <% end %>
          </div>
          
          <!-- Navigation Links -->
          <div class="hidden md:flex space-x-4">
            <% if logged_in? %>
              <%= link_to current_user, class: "text-white hover:bg-white hover:bg-opacity-20 px-3 py-2 rounded-md text-sm font-medium transition-all duration-200" do %>
                <i class="fas fa-user mr-1"></i>Mi Perfil
              <% end %>
              <%= link_to edit_user_path(current_user), class: "text-white hover:bg-white hover:bg-opacity-20 px-3 py-2 rounded-md text-sm font-medium transition-all duration-200" do %>
                <i class="fas fa-edit mr-1"></i>Editar
              <% end %>
              <%= link_to logout_path, method: :delete, class: "bg-red-500 hover:bg-red-600 text-white px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200" do %>
                <i class="fas fa-sign-out-alt mr-1"></i>Cerrar Sesión
              <% end %>
            <% else %>
              <%= link_to login_path, class: "text-white hover:bg-white hover:bg-opacity-20 px-3 py-2 rounded-md text-sm font-medium transition-all duration-200" do %>
                <i class="fas fa-sign-in-alt mr-1"></i>Iniciar Sesión
              <% end %>
              <%= link_to signup_path, class: "bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors duration-200" do %>
                <i class="fas fa-user-plus mr-1"></i>Registrarse
              <% end %>
            <% end %>
          </div>
          
          <!-- Mobile menu button -->
          <div class="md:hidden">
            <button type="button" class="text-white hover:text-gray-200 focus:outline-none focus:ring-2 focus:ring-white" id="mobile-menu-button">
              <i class="fas fa-bars"></i>
            </button>
          </div>
        </div>
        
        <!-- Mobile menu -->
        <div class="md:hidden hidden" id="mobile-menu">
          <div class="px-2 pt-2 pb-3 space-y-1 border-t border-white border-opacity-20">
            <% if logged_in? %>
              <%= link_to current_user, class: "text-white hover:bg-white hover:bg-opacity-20 block px-3 py-2 rounded-md text-sm font-medium" do %>
                <i class="fas fa-user mr-1"></i>Mi Perfil
              <% end %>
              <%= link_to edit_user_path(current_user), class: "text-white hover:bg-white hover:bg-opacity-20 block px-3 py-2 rounded-md text-sm font-medium" do %>
                <i class="fas fa-edit mr-1"></i>Editar
              <% end %>
              <%= link_to logout_path, method: :delete, class: "text-white hover:bg-white hover:bg-opacity-20 block px-3 py-2 rounded-md text-sm font-medium" do %>
                <i class="fas fa-sign-out-alt mr-1"></i>Cerrar Sesión
              <% end %>
            <% else %>
              <%= link_to login_path, class: "text-white hover:bg-white hover:bg-opacity-20 block px-3 py-2 rounded-md text-sm font-medium" do %>
                <i class="fas fa-sign-in-alt mr-1"></i>Iniciar Sesión
              <% end %>
              <%= link_to signup_path, class: "text-white hover:bg-white hover:bg-opacity-20 block px-3 py-2 rounded-md text-sm font-medium" do %>
                <i class="fas fa-user-plus mr-1"></i>Registrarse
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    
    <!-- Main Content -->
    <main class="flex-1">
      <!-- Flash Messages -->
      <% flash.each do |type, msg| %>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
          <div class="<%= type == 'notice' ? 'bg-green-100 border-green-400 text-green-700' : 'bg-red-100 border-red-400 text-red-700' %> px-4 py-3 rounded-lg border-l-4 shadow-md">
            <div class="flex items-center">
              <i class="<%= type == 'notice' ? 'fas fa-check-circle' : 'fas fa-exclamation-triangle' %> mr-2"></i>
              <span><%= msg %></span>
              <button type="button" class="ml-auto text-gray-400 hover:text-gray-600" onclick="this.parentElement.parentElement.remove()">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
        </div>
      <% end %>
      
      <!-- Page Content -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <%= yield %>
      </div>
    </main>
    
    <!-- Font Awesome para iconos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- JavaScript para el menú móvil -->
    <script>
      document.getElementById('mobile-menu-button').addEventListener('click', function() {
        const menu = document.getElementById('mobile-menu');
        menu.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
