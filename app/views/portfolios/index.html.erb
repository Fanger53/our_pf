<% content_for :title, "Mis Portfolios" %>

<div class="max-w-6xl mx-auto">
  <!-- Header -->
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Mis Portfolios</h1>
      <p class="text-gray-600 mt-2">Gestiona y personaliza tus portfolios</p>
    </div>
    <%= link_to new_user_portfolio_path(@user), class: "bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 transform hover:scale-105 shadow-lg" do %>
      <i class="fas fa-plus mr-2"></i>
      Nuevo Portfolio
    <% end %>
  </div>

  <!-- Portfolios Grid -->
  <% if @portfolios.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @portfolios.each do |portfolio| %>
        <div class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 overflow-hidden border border-gray-100">
          <!-- Portfolio Header -->
          <div class="bg-gradient-to-r from-blue-500 to-purple-600 p-6 text-white">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-xl font-bold truncate"><%= portfolio.title %></h3>
              <span class="<%= portfolio.published? ? 'bg-green-500' : 'bg-yellow-500' %> text-white text-xs px-2 py-1 rounded-full">
                <%= portfolio.published? ? 'Público' : 'Privado' %>
              </span>
            </div>
            <p class="text-blue-100 text-sm"><%= portfolio.template_name %></p>
          </div>
          
          <!-- Portfolio Content -->
          <div class="p-6">
            <p class="text-gray-600 mb-4 line-clamp-3">
              <%= portfolio.description.present? ? portfolio.description : "Sin descripción" %>
            </p>
            
            <div class="text-sm text-gray-500 mb-4">
              <div class="flex items-center mb-1">
                <i class="fas fa-layer-group mr-2"></i>
                <%= pluralize(portfolio.portfolio_sections.count, 'sección', 'secciones') %>
              </div>
              <div class="flex items-center">
                <i class="fas fa-calendar mr-2"></i>
                Creado <%= time_ago_in_words(portfolio.created_at) %>
              </div>
            </div>
            
            <!-- Actions -->
            <div class="flex space-x-2">
              <%= link_to [@user, portfolio], class: "flex-1 bg-blue-500 hover:bg-blue-600 text-white text-center py-2 px-3 rounded-lg text-sm transition-colors duration-200" do %>
                <i class="fas fa-eye mr-1"></i>Ver
              <% end %>
              
              <%= link_to edit_user_portfolio_path(@user, portfolio), class: "flex-1 bg-gray-500 hover:bg-gray-600 text-white text-center py-2 px-3 rounded-lg text-sm transition-colors duration-200" do %>
                <i class="fas fa-edit mr-1"></i>Editar
              <% end %>
              
              <% if portfolio.published? %>
                <%= link_to public_portfolio_path(portfolio.slug), target: '_blank', class: "flex-1 bg-green-500 hover:bg-green-600 text-white text-center py-2 px-3 rounded-lg text-sm transition-colors duration-200" do %>
                  <i class="fas fa-external-link-alt mr-1"></i>Ver Público
                <% end %>
              <% end %>
            </div>
            
            <!-- URL Preview -->
            <% if portfolio.published? %>
              <div class="mt-3 p-2 bg-gray-50 rounded-lg">
                <p class="text-xs text-gray-600">URL pública:</p>
                <p class="text-sm font-mono text-blue-600 truncate">
                  <%= request.base_url %>/<%= portfolio.slug %>
                </p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-16">
      <div class="max-w-md mx-auto">
        <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-folder-open text-gray-400 text-3xl"></i>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">No tienes portfolios aún</h3>
        <p class="text-gray-600 mb-6">
          Crea tu primer portfolio para mostrar tus proyectos y habilidades al mundo.
        </p>
        <%= link_to new_user_portfolio_path(@user), class: "bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 transform hover:scale-105 shadow-lg" do %>
          <i class="fas fa-plus mr-2"></i>
          Crear Mi Primer Portfolio
        <% end %>
      </div>
    </div>
  <% end %>
</div>
